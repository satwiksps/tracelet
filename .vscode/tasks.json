{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "problemMatcher": [
        {
          "base": "$esbuild-watch",
          "background": {
            "beginsPattern": "^\\[tracelet\\] build started$",
            "endsPattern": "^\\[tracelet\\] build finished$"
          }
        }
      ],
      "isBackground": true,
      "presentation": {
        "reveal": "never"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "label": "npm: watch"
    },
    {
      "type": "npm",
      "script": "build",
      "group": "build",
      "problemMatcher": "$esbuild",
      "label": "npm: build"
    },
    {
      "type": "npm",
      "script": "lint",
      "group": "test",
      "problemMatcher": "$eslint-stylish",
      "label": "npm: lint"
    }
  ]
}
